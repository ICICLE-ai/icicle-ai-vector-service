  "components": {
    "schemas": {
      "DeleteResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "deleted": {
            "type": "boolean",
            "title": "Deleted"
          }
        },
        "type": "object",
        "required": [
          "id",
          "user_id",
          "deleted"
        ],
        "title": "DeleteResponse"
      },
      "EmbeddingCreate": {
        "properties": {
          "embedding": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Embedding"
          },
          "topic": {
            "type": "string",
            "title": "Topic"
          },
          "chunks": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Chunks"
          },
          "token_ids": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Token Ids"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          },
          "embedding_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Embedding Model"
          }
        },
        "type": "object",
        "required": [
          "embedding",
          "topic",
          "chunks"
        ],
        "title": "EmbeddingCreate"
      },
      "EmbeddingRecord": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "topic": {
            "type": "string",
            "title": "Topic"
          },
          "created_at": {
            "type": "string",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "title": "Updated At"
          },
          "embedding_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Embedding Model"
          }
        },
        "type": "object",
        "required": [
          "id",
          "user_id",
          "topic",
          "created_at",
          "updated_at"
        ],
        "title": "EmbeddingRecord"
      },
      "EmbeddingUpdate": {
        "properties": {
          "embedding": {
            "anyOf": [
              {
                "items": {
                  "type": "number"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Embedding"
          },
          "topic": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Topic"
          },
          "chunks": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chunks"
          },
          "token_ids": {
            "anyOf": [
              {
                "items": {
                  "type": "integer"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Token Ids"
          },
          "metadata": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Metadata"
          },
          "embedding_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Embedding Model"
          }
        },
        "type": "object",
        "title": "EmbeddingUpdate"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MetadataFilter": {
        "properties": {
          "conditions": {
            "additionalProperties": true,
            "type": "object",
            "title": "Conditions",
            "description": "Key-value pairs to match against the metadata payload field"
          }
        },
        "type": "object",
        "title": "MetadataFilter",
        "description": "Filter search results by metadata fields.\n\nEach key-value pair matches against the nested ``metadata`` payload field.\nAll conditions are ANDed together.  Values can be:\n  - a string/number/bool for exact match\n  - a list for \"any of\" match"
      },
      "RerankRequest": {
        "properties": {
          "query_embedding": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Query Embedding"
          },
          "top_k": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Top K",
            "default": 10
          },
          "fetch_k": {
            "type": "integer",
            "maximum": 500.0,
            "minimum": 1.0,
            "title": "Fetch K",
            "default": 50
          },
          "method": {
            "type": "string",
            "title": "Method",
            "default": "mmr"
          },
          "lambda": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Lambda",
            "default": 0.7
          },
          "topic": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Topic"
          },
          "filter": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/MetadataFilter"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "query_embedding"
        ],
        "title": "RerankRequest"
      },
      "RerankResponse": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "method": {
            "type": "string",
            "title": "Method"
          },
          "top_k": {
            "type": "integer",
            "title": "Top K"
          },
          "fetch_k": {
            "type": "integer",
            "title": "Fetch K"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/ResultItem"
            },
            "type": "array",
            "title": "Results"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "method",
          "top_k",
          "fetch_k",
          "results"
        ],
        "title": "RerankResponse"
      },
      "ResultItem": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "topic": {
            "type": "string",
            "title": "Topic"
          },
          "text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Text"
          },
          "chunks": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Chunks"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "id",
          "score",
          "topic",
          "chunks",
          "metadata"
        ],
        "title": "ResultItem"
      },
      "RetrieveRequest": {
        "properties": {
          "query_embedding": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Query Embedding"
          },
          "top_k": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Top K",
            "default": 10
          },
          "topic": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Topic"
          },
          "filter": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/MetadataFilter"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "query_embedding"
        ],
        "title": "RetrieveRequest"
      },
      "RetrieveResponse": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "top_k": {
            "type": "integer",
            "title": "Top K"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/ResultItem"
            },
            "type": "array",
            "title": "Results"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "top_k",
          "results"
        ],
        "title": "RetrieveResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
